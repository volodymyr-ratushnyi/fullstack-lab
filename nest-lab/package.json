    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.32",
    "@types/cookie-parser": "^1",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8",
    "@types/pg": "^8",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.5",
